[Desktop Entry]
Version=1.0
Type=Application
Name=CodexSystem AI
GenericName=AI Desktop Environment
Comment=Autostart CodexOS Desktop Environment (Chromium)
Exec=/usr/local/bin/codexsystem-launch
Icon=codexsystem
